BOMIPAY_ENV=development
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/bomipay
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-min-32-chars-replace-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=604800
PROVIDER_ENCRYPTION_KEY=replace-with-a-32-byte-url-safe-base64-key

# CORS (comma-separated list of allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Sentry (optional)
SENTRY_DSN=

# OpenTelemetry (optional)
OTEL_EXPORTER_OTLP_ENDPOINT=

# Rate limiting
RATE_LIMIT_ENABLED=true

# API docs (disable in production)
DOCS_ENABLED=true

# Security headers
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# Provider API Keys (set per merchant via admin)
# These are placeholders — actual keys stored encrypted in DB
PAYSTACK_DEFAULT_API_KEY=
FLUTTERWAVE_DEFAULT_API_KEY=
MONNIFY_DEFAULT_API_KEY=
