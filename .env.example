BOMIPAY_ENV=development
DATABASE_URL=postgresql+asyncpg://bomipay:changeme@db:5432/bomipay
REDIS_URL=redis://redis:6379/0
SECRET_KEY=replace-with-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=604800
PROVIDER_ENCRYPTION_KEY=replace-with-a-32-byte-url-safe-base64-key
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
