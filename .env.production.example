# Bomi Pay Production Configuration

# Environment & App Identity
BOMIPAY_ENV=production
SECRET_KEY=your-64-character-random-secret-key-replace-this-with-strong-random-value

# Database (use RDS or managed database in production)
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://bomipay:CHANGE_ME_STRONG_PASSWORD@db:5432/bomipay_prod

# Redis (use ElastiCache or managed Redis in production)
# Format: redis://[:password@]host:port/db
REDIS_URL=redis://redis:6379/0

# Security & Authentication
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=900
JWT_REFRESH_TOKEN_EXPIRE_SECONDS=604800
PROVIDER_ENCRYPTION_KEY=replace-with-a-32-byte-url-safe-base64-key

# CORS Configuration (comma-separated list)
CORS_ALLOWED_ORIGINS=https://bomipay.ng,https://dashboard.bomipay.ng,https://api.bomipay.ng

# API Documentation (disable in production)
DOCS_ENABLED=false

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_PERIOD=60

# Security Headers
HSTS_MAX_AGE=31536000
CSP_ENABLED=true

# Observability & Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project_id
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector:4317
LOG_LEVEL=info

# AWS / Cloud Storage (optional, for file uploads)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
STORAGE_BUCKET=bomipay-prod

# Payment Provider API Keys (use secure secrets manager in production)
# These should be stored in secrets manager, not in .env in production
PAYSTACK_DEFAULT_API_KEY=sk_live_your_paystack_key
FLUTTERWAVE_DEFAULT_API_KEY=fl_live_your_flutterwave_key
MONNIFY_DEFAULT_API_KEY=mn_live_your_monnify_key

# Email Configuration (SendGrid, AWS SES, etc.)
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your_sendgrid_api_key
EMAIL_FROM=noreply@bomipay.ng

# Optional: Feature Flags
FEATURE_SETTLEMENTS_ENABLED=true
FEATURE_AI_ASSISTANT_ENABLED=true
FEATURE_MOBILE_APP_ENABLED=false

# Optional: CDN & Frontend URLs
FRONTEND_URL=https://bomipay.ng
DASHBOARD_URL=https://dashboard.bomipay.ng

# Optional: Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=daily
BACKUP_RETENTION_DAYS=30
